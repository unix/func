{
  "compilerOptions": {
    "moduleResolution": "node",
    "module": "commonjs",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "rootDir": "src",
    "outDir": "dist",
    "esModuleInterop": true,
    "removeComments": true,
    "declaration": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true
  },
  "files": ["src/index.ts"],
  "exclude": ["node_modules", "dist"]
}
