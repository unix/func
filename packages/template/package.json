{
  "name": "func-template",
  "version": "1.0.1",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "dev": "funcgo dev --",
    "build": "funcgo build",
    "test": "pnpm build && vitest run",
    "format": "prettier --write ."
  },
  "files": [
    "src",
    "tests",
    "README.md",
    "template-readme.md",
    "tsconfig.json",
    ".gitignore"
  ],
  "func": {
    "entry": "src/index.ts",
    "outDir": "dist"
  },
  "bin": {
    "template": "./dist/bin.js"
  },
  "dependencies": {
    "func": "latest"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "funcgo": "latest",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
