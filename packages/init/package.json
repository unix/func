{
  "name": "create-func",
  "version": "0.4.3",
  "main": "dist/index.js",
  "license": "MIT",
  "bin": {
    "create-func": "./dist/index.js"
  },
  "scripts": {
    "build": "pnpm clean && ncc build src/bin.ts -o dist --minify && pnpm chmod-bin",
    "clean": "node -e \"require('fs').rmSync('dist', { force: true, recursive: true })\"",
    "chmod-bin": "node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "dev": "ts-node src/bin.ts",
    "test": "vitest run",
    "test:file": "vitest run",
    "release": "pnpm build && pnpm publish --access public --no-git-checks",
    "format": "prettier --write ."
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unix/func.git",
    "directory": "packages/init"
  },
  "prettier": "@norehq/prettier",
  "dependencies": {
    "args": "^5.0.3",
    "tar": "^7.5.15"
  },
  "devDependencies": {
    "@norehq/prettier": "^0.1.0",
    "@swc/core": "^1.15.40",
    "@types/args": "^5.0.4",
    "@types/node": "^25.9.1",
    "@vercel/ncc": "^0.38.4",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.9",
    "vite": "^6.4.2",
    "vitest": "^4.1.7"
  }
}
