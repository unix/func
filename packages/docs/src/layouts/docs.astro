---
import DocsHeader from '@/components/DocsHeader.astro'
import DocsSidebar from '@/components/DocsSidebar.astro'
import { defaultLocale, getSiteTitle, type DocPage, type Locale } from '@/lib/docs'
import Layout from '@/layouts/main.astro'

interface Props {
  description?: string
  locale?: Locale
  page: DocPage
  title?: string
}

const {
  description = 'Modern Command Line Framework.',
  locale = defaultLocale,
  page,
  title = getSiteTitle(locale),
} = Astro.props
---

<Layout title={title} description={description}>
  <main class="mx-auto min-h-screen w-full max-w-6xl px-6 py-8 md:px-8 md:py-10">
    <DocsHeader locale={locale} page={page} />

    <div class="grid min-w-0 gap-10 py-10 lg:grid-cols-[13rem_minmax(0,1fr)]">
      <DocsSidebar locale={locale} page={page} />

      <article class="prose-static min-w-0 max-w-full lg:max-w-3xl">
        <slot />
      </article>
    </div>
  </main>
</Layout>
