---
import {
  defaultLocale,
  getLanguageSwitch,
  getLocalePath,
  getSiteTitle,
  type DocPage,
  type Locale,
} from '@/lib/docs'

interface Props {
  locale?: Locale
  page?: DocPage
}

const { locale = defaultLocale, page = '/' } = Astro.props
const languageSwitch = getLanguageSwitch(page, locale)
const siteTitle = getSiteTitle(locale)
---

<header
  class="flex w-full items-center justify-between gap-4 border-b border-border pb-6">
  <a
    class="min-w-0 break-words text-sm font-semibold tracking-wide text-foreground"
    href={getLocalePath('/', locale)}>
    {siteTitle}
  </a>
  <div class="flex shrink-0 items-center gap-1">
    <a
      class="inline-flex h-8 items-center rounded-md px-2 text-sm font-medium text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
      href={languageSwitch.href}>
      {languageSwitch.label}
    </a>
    <a
      aria-label="Open FUNC on GitHub"
      class="inline-flex size-8 items-center justify-center rounded-md text-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
      href="https://github.com/unix/func"
      rel="noreferrer"
      target="_blank">
      <svg
        aria-hidden="true"
        class="size-5"
        fill="none"
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg">
        <path
          d="M9.94118 17.8796C9.94118 17.5162 10.0494 17.2003 10.2238 16.915C10.3434 16.7192 10.2615 16.4414 10.0453 16.3801C8.25526 15.8719 7 15.0547 7 12.3443C7 11.6397 7.22356 10.9772 7.61654 10.4006C7.71414 10.2573 7.76181 10.1922 7.77491 10.1208C7.78806 10.049 7.76638 9.97088 7.72543 9.80094C7.58167 9.20442 7.57017 8.57599 7.73081 7.98978C7.78361 7.79709 7.8968 7.6847 8.10166 7.7064C8.3674 7.73454 8.82753 7.86036 9.50999 8.30066C9.77813 8.47365 9.9122 8.56015 10.0303 8.5795C10.1484 8.59885 10.3062 8.55832 10.622 8.47727C11.0537 8.36642 11.4986 8.30692 12 8.30692C12.5014 8.30692 12.9463 8.36642 13.378 8.47726C13.6938 8.55832 13.8516 8.59885 13.9697 8.5795C14.0878 8.56015 14.2219 8.47366 14.49 8.30066C15.1725 7.86037 15.6326 7.73454 15.8983 7.7064C16.1032 7.6847 16.2164 7.79709 16.2692 7.98978C16.4298 8.57599 16.4183 9.20441 16.2746 9.80093C16.2336 9.97087 16.2119 10.049 16.2251 10.1208C16.2382 10.1922 16.2859 10.2573 16.3834 10.4005C16.7764 10.9771 17 11.6397 17 12.3443C17 15.0547 15.7447 15.8719 13.9547 16.3801C13.7385 16.4414 13.6566 16.7192 13.7762 16.915C13.9506 17.2003 14.0588 17.5162 14.0588 17.8796V22.6507C19.011 21.6902 22.75 17.3306 22.75 12.0977C22.75 6.1606 17.9371 1.34766 12 1.34766C6.06294 1.34766 1.25 6.1606 1.25 12.0977C1.25 17.3306 4.98901 21.6902 9.94118 22.6507V19.851C9.88484 19.8444 9.81816 19.8347 9.74225 19.8202C9.52615 19.7792 9.23571 19.7005 8.89714 19.5503C8.21489 19.2478 7.36263 18.6661 6.53685 17.5655C6.28826 17.2342 6.35533 16.7641 6.68665 16.5155C7.01798 16.2669 7.48809 16.334 7.73668 16.6653C8.4109 17.5639 9.06058 17.9819 9.50527 18.1791C9.6822 18.2576 9.83089 18.303 9.94118 18.3292V17.8796Z"
          fill="currentColor"></path>
      </svg>
    </a>
  </div>
</header>
