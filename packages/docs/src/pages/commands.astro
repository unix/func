---
import CodeBlock from '@/components/CodeBlock.astro'
import DocsLayout from '@/layouts/docs.astro'

const commandCode = `import { Command, Handler } from 'func'

@Command({
  name: 'config',
  alias: 'c',
})
export class ConfigCommand {
  @Handler({ path: ['get'] })
  get() {
    console.log('get config')
  }

  @Handler({ flag: 'help', alias: 'h' })
  help() {
    console.log('usage')
  }

  @Handler()
  run() {
    console.log('default')
  }
}`
---

<DocsLayout page="commands">
  <h1>Commands</h1>
  <p>
    Command docs have moved into <a href="/concepts">Core Concepts</a> so the left navigation
    stays compact. The current command model supports default handlers, flag handlers,
    and path handlers:
  </p>
  <CodeBlock code={commandCode} lang="ts" />
  <p>
    See the <a href="/apis">API Reference</a> for the exact decorator signatures.
  </p>
</DocsLayout>
