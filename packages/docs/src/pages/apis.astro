---
import DocsLayout from '@/layouts/docs.astro'

const commandApis = [
  {
    signature: '@Command(params: CommandParams)',
    structure:
      'CommandParams = { name: string, description?: string, alias?: string }',
    description:
      'Register a named command. The name or alias is matched against the first input token.',
  },
  {
    signature: '@Handler(params?: HandlerParams)',
    structure:
      'HandlerParams = { flag?: string, alias?: string, description?: string, path?: string[] }',
    description:
      'Register a default handler, flag handler, or path handler. path cannot be combined with flag or alias.',
  },
  {
    signature: '@SubOptions(params: Array<OptionParams>)',
    structure:
      'OptionParams = { name: string, type?: Boolean | String | Number | [String], description?: string, alias?: string }',
    description:
      'Add parse-only options for the current command scope. Field options are preferred for values read from the command instance.',
  },
  {
    signature: '@CommandMissing()',
    structure: '-',
    description:
      'Register a fallback command for bare input whose first token is not a known command. It can define handlers and field options like a normal command.',
  },
  {
    signature: '@CommandMajor()',
    structure: '-',
    description:
      'Register the major command for empty invocation and top-level options.',
  },
  {
    signature: '@Catch()',
    structure: '-',
    description:
      'Register a local command error method. It runs before global error handlers.',
  },
  {
    signature: '@CatchAll() / @CommandError()',
    structure: '-',
    description:
      'Register a global error handler class. CommandError is an alias for CatchAll.',
  },
]

const fieldApis = [
  {
    signature: '@Flag(params?)',
    structure: 'params = { name?: string, alias?: string, description?: string }',
    description: 'Declare a boolean option assigned to the decorated property.',
  },
  {
    signature: '@Value(params?)',
    structure:
      'params = { name?: string, alias?: string, description?: string, type?: Boolean | String | Number | [String], required?: boolean }',
    description:
      'Declare a scalar value option. The type is inferred from design metadata when possible.',
  },
  {
    signature: '@ArrayValue(params?)',
    structure: 'params = { name?: string, alias?: string, description?: string }',
    description: 'Declare a repeated string option assigned as a string array.',
  },
  {
    signature: '@Required()',
    structure: '-',
    description:
      'Require the option to be provided explicitly or have a defined value.',
  },
  {
    signature: '@Enum(values)',
    structure: 'values = Array<boolean | string | number>',
    description:
      'Validate that a scalar value, or every array item, is one of the allowed values.',
  },
  {
    signature: '@DependsOn(options)',
    structure: 'options = string[]',
    description: 'Require other options when this option is explicitly provided.',
  },
  {
    signature: '@Exclusive(options)',
    structure: 'options = string[]',
    description:
      'Reject combinations where this option and one of the listed options are both explicit.',
  },
  {
    signature: '@ValueValidate(fn)',
    structure: 'fn(value, options) => boolean | string | void',
    description:
      'Run a custom validator. Return false or a string to create a validation error.',
  },
]

const contextApis = [
  {
    signature: '@Args()',
    description:
      'Inject FuncArgs: command metadata, selected handler, inputs, path, normalized option, and native parse data.',
  },
  {
    signature: '@Regs()',
    description: 'Inject CommandRegistry for registered command metadata.',
  },
  {
    signature: '@Exception()',
    description:
      'Inject FuncException into local catch methods and global error handlers.',
  },
]

const appApis = [
  {
    signature: '@FuncModule(params)',
    structure:
      'params = { commands?: Class[], imports?: FuncModuleInput[], services?: Class[] }',
    description: 'Create an application or feature module.',
  },
  {
    signature: '@Service()',
    structure: '-',
    description:
      'Mark a service class that can be injected into commands or other registered services.',
  },
  {
    signature: 'run(input, options?)',
    structure: 'options = { argv?: string[], services?: Class[] }',
    description: 'Create an app and execute it.',
  },
  {
    signature: 'createApp(input, options?)',
    structure: 'options = { argv?: string[], services?: Class[] }',
    description: 'Create the low-level Container without running it.',
  },
]

const typesApis = [
  {
    signature: 'FuncArgs',
    structure:
      '{ command?, handler?, inputs: string[], native, option: UserOption, path: string[] }',
    description: 'Normalized runtime context injected by Args.',
  },
  {
    signature: 'FuncException',
    structure: 'code, details, error, level, message, type, preventDefaultPrint()',
    description: 'Wrapper around FuncError used by catch and error handlers.',
  },
  {
    signature: 'CommandRegistry',
    structure: '{ commands: RegisterCommandParams[] }',
    description: 'Read-only registry context injected by Regs.',
  },
]

const supportApis = [
  {
    signature: 'funcgo setup',
    structure: '--fix?',
    description:
      'Inspect package.json and suggest missing func.entry, func.outDir, bin, dev script, and build script configuration.',
  },
  {
    signature: 'funcgo dev',
    structure: '-f, --file <entry>; -- <args>',
    description:
      'Run the project entry with a local TypeScript runtime and pass arguments through to the command.',
  },
  {
    signature: 'funcgo build',
    structure: '-f, --file <entry>; -o, --out <dir>; -e, --external <package>',
    description:
      'Bundle the project entry for production, write output to func.outDir or dist, and create the executable bin.js.',
  },
]

const supportConfigs = [
  {
    signature: 'package.json#func.entry',
    description:
      'Default TypeScript entry file used by funcgo dev and funcgo build when --file is not provided.',
  },
  {
    signature: 'package.json#func.outDir',
    description:
      'Default build output directory used by funcgo build when --out is not provided.',
  },
]
---

<DocsLayout page="apis">
  <h1>API Reference</h1>
  <p>
    This page is the compact reference for current <code>func</code> core APIs and
    <code>funcgo</code> support commands. See <a href="/concepts">Core Concepts</a>,
    <a href="/options">Field Options</a>, <a href="/parameters">Parameters</a>, and <a
      href="/errors">Errors</a
    > for behavior details.
  </p>
  <h2>Commands</h2>
  <div class="overflow-x-auto">
    <table>
      <thead>
        <tr>
          <th>Signature</th>
          <th>Structure</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        {
          commandApis.map(item => (
            <tr>
              <td>
                <code>{item.signature}</code>
              </td>
              <td>
                <code>{item.structure}</code>
              </td>
              <td>{item.description}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <h2>Field Options and Validators</h2>
  <div class="overflow-x-auto">
