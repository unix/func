---
import CodeBlock from '@/components/CodeBlock.astro'
import DocsLayout from '@/layouts/docs.astro'

const majorCode = `import { CommandMajor, Handler } from 'func'

@CommandMajor()
export class MajorCommand {
  @Handler()
  run() {
    console.log('welcome')
  }
}`

const commandCode = `import { Command, Handler } from 'func'

@Command({ name: 'build', alias: 'b' })
export class BuildCommand {
  @Handler()
  run() {
    console.log('build')
  }
}`

const missingCode = `import { CommandMissing } from 'func'

@CommandMissing()
export class MissingCommand {
  constructor() {
    console.log('unknown command')
  }
}`

const commandScopes = [
  {
    input: 'my-cli',
    target: 'MajorCommand',
    reason: 'There is no command name, so the major command runs.',
  },
  {
    input: 'my-cli build',
    target: 'BuildCommand',
    reason: 'The first input token matches build.',
  },
  {
    input: 'my-cli b',
    target: 'BuildCommand',
    reason: 'The first input token matches the command alias.',
  },
]

const missingScope = {
  input: 'my-cli unknown',
  target: 'MissingCommand',
  reason: 'The first input token is not a registered command.',
}

const handlerCode = `import { Command, Handler } from 'func'

@Command({ name: 'config' })
export class ConfigCommand {
  @Handler({ path: ['get'] })
  get() {
    console.log('get config')
  }

  @Handler({ flag: 'help', alias: 'h' })
  help() {
    console.log('usage')
  }

  @Handler()
  run() {
    console.log('config')
  }
}`

const moduleCode = `import { Command, FuncModule, Handler, Service, run } from 'func'

@Service()
class ProjectService {
  name() {
    return 'demo'
  }
}

@Command({ name: 'build' })
class BuildCommand {
  constructor(private project: ProjectService) {}

  @Handler()
  run() {
    console.log(this.project.name())
  }
}

@FuncModule({
  commands: [BuildCommand],
  services: [ProjectService],
})
class AppModule {}

run(AppModule)`
---

<DocsLayout page="concepts">
  <h1>Core Concepts</h1>
  <p>
    A <code>func</code> app registers decorated classes in a
    <code>FuncModule</code>. At runtime, <code>func</code> finds the class that matches
    the user's CLI input, selects one handler method, injects fields and parameters, then
    runs the handler.
  </p>

  <h2>Command Scopes</h2>
  <p>
    A command scope is the class that owns the current CLI input. Start with the two
    common cases: no command name, and a named command.
  </p>

  <h3>Major Command</h3>
  <p>
    <code>@CommandMajor</code> runs when the user invokes the CLI without a command name.
  </p>
  <CodeBlock code={majorCode} lang="ts" />

  <h3>Named Command</h3>
  <p>
    <code>@Command</code> runs when the first input token matches its
    <code>name</code> or <code>alias</code>.
  </p>
  <CodeBlock code={commandCode} lang="ts" />
  <div class="overflow-x-auto">
    <table>
      <thead>
        <tr>
          <th>User Input</th>
          <th>Runs</th>
          <th>Why</th>
        </tr>
      </thead>
      <tbody>
        {
          commandScopes.map(item => (
            <tr>
              <td>
                <code>{item.input}</code>
              </td>
              <td>
                <code>{item.target}</code>
              </td>
              <td>{item.reason}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <h3>Unknown Command</h3>
  <p>
    <code>@CommandMissing</code> is optional. Use it when you want a custom message for
    input that does not match any named command.
  </p>
  <CodeBlock code={missingCode} lang="ts" />
  <div class="overflow-x-auto">
    <table>
      <thead>
        <tr>
          <th>User Input</th>
          <th>Runs</th>
          <th>Why</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>
            <code>{missingScope.input}</code>
          </td>
          <td>
            <code>{missingScope.target}</code>
          </td>
          <td>{missingScope.reason}</td>
        </tr>
      </tbody>
    </table>
  </div>

  <h2>Handlers</h2>
  <p>
    Every command scope needs at least one <code>@Handler</code> method. A handler can
    be the default method, a flag-triggered method, or a path method. Path handlers are
    checked before flag handlers, and the longest matching path wins.
  </p>
  <CodeBlock code={handlerCode} lang="ts" />
  <p>
    For <code>my-cli config get</code>, the path handler runs. For
    <code>my-cli config --help</code>, the flag handler runs. If no path or flag
    handler matches, the default handler runs.
  </p>

  <h2>Modules and Services</h2>
  <p>
    <code>@FuncModule</code> can register commands, import feature modules, and register
    services. Services are instantiated once and can depend on other registered services.
  </p>
  <CodeBlock code={moduleCode} lang="ts" />

  <h2>Next Topics</h2>
  <p>
    Use <a href="/options">Field Options</a> for flags and values,
    <a href="/parameters">Parameters</a> for <code>@Args</code>,
    <code>@Regs</code>, and <code>@Exception</code>, and <a href="/errors">Errors</a>
    for local and global error handling.
  </p>
</DocsLayout>
