---
import DocsLayout from '@/layouts/docs.astro'

const projectTree = `.
|-- src
|   |-- commands            main command files
|   |   |-- hello.ts        "<Command> hello"
|   |   |-- major.ts        "<Command>"
|   |   +-- index.ts        entry file
|   |-- options             options files
|   |   |-- help.ts         "<Command> --help"
|   |   |-- version.ts      "<Command> --version"
|   |   +-- index.ts        entry file
|   +-- index.ts            entry file
|-- tests                   testcases
|   |-- commands            test for commands
|   +-- utils               test utils
|-- package.json
|-- tsconfig.json
+-- README.md`

const npmCreateCode = `npm init func
# or
pnpm create func`

const npmInstallCode = `npm i
npm run dev --`

const npmRunCode = `npm run dev -- hello
npm run dev -- --version`

const npmBuildCode = 'npm run build'
---

<DocsLayout page="guide">
  <h1>Quick Start</h1>
  <p>
    Ensure you have the latest version of <a href="https://nodejs.org/en/download/"
      >NodeJS</a
    > and a package manager such as <a href="https://www.npmjs.com/">NPM</a>.
    Running one command starts the interactive project creator:
  </p>
  <pre set:text={npmCreateCode} />

  <h2>Development</h2>
  <p>After you create an initial project, you will see these files:</p>
  <pre set:text={projectTree} />
  <p>
    Before editing, install the dependencies and set up the development environment:
  </p>
  <pre set:text={npmInstallCode} />
  <p>At this point, all preparation is complete.</p>
  <p>
    You can browse the examples in <code>commands</code> and <code>options</code>,
    modify them, and run your commands through the local TypeScript entry:
  </p>
  <pre set:text={npmRunCode} />

  <h2>Bundle</h2>
  <p>
    If you use the template to create a project, you only need one command to package
    it:
  </p>
  <pre set:text={npmBuildCode} />
  <p>
    After running the command, your project is packaged into the configured output
    directory.
  </p>
  <p>
    When using <code>func</code>, you do not need to think about <code>bin</code>
    files, file updates, or symlink problems. <code>func</code> handles all of that automatically,
    so you can publish immediately.
  </p>
  <blockquote>
    If you need to return to development mode, run <code>npm run dev</code> again.
  </blockquote>

  <h2>Publish</h2>
  <p>
    Publish your package after the build output has been generated. The template
    already points <code>package.json#bin</code> at the generated executable.
  </p>
</DocsLayout>
