      </tbody>
    </table>
  </div>

  <h2>应用</h2>
  <div class="overflow-x-auto">
    <table>
      <thead>
        <tr>
          <th>签名</th>
          <th>结构</th>
          <th>描述</th>
        </tr>
      </thead>
      <tbody>
        {
          appApis.map(item => (
            <tr>
              <td>
                <code>{item.signature}</code>
              </td>
              <td>
                <code>{item.structure}</code>
              </td>
              <td>{item.description}</td>
            </tr>
          ))
