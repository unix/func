{
  "name": "funcgo",
  "version": "0.1.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "bin": {
    "funcgo": "./dist/bin.js"
  },
  "scripts": {
    "build": "pnpm clean && tsc && pnpm chmod-bin",
    "clean": "node -e \"require('fs').rmSync('dist', { force: true, recursive: true })\"",
    "chmod-bin": "node -e \"require('fs').chmodSync('dist/bin.js', 0o755)\"",
    "test": "vitest run",
    "test:file": "vitest run",
    "release": "pnpm build && pnpm publish --access public --no-git-checks",
    "format": "prettier --write ."
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unix/func.git",
    "directory": "packages/funcgo"
  },
  "prettier": "@norehq/prettier",
  "dependencies": {
    "@vercel/ncc": "^0.38.4",
    "arg": "^5.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^4.5.5"
  },
  "devDependencies": {
    "@norehq/prettier": "^0.1.0",
    "@swc/core": "^1.15.40",
    "@types/node": "^20.10.0",
    "prettier": "^3.8.3",
    "unplugin-swc": "^1.5.9",
    "vite": "^6.4.2",
    "vitest": "^4.1.7"
  }
}
