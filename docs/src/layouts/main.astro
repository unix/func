---
import '../styles/global.css'

interface Props {
  content?: {
    description?: string
    title?: string
  }
  description?: string
  frontmatter?: {
    description?: string
    title?: string
  }
  title?: string
}

const frontmatter = Astro.props.frontmatter ?? Astro.props.content ?? {}
const title = Astro.props.title ?? frontmatter.title ?? 'Func Docs'
const description =
  Astro.props.description ?? frontmatter.description ?? 'Documentation for func.'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <slot />
  </body>
</html>
