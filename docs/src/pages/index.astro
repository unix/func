---
import { Button } from '@/components/ui/button'
import Layout from '@/layouts/main.astro'
---

<Layout title="Func Docs" description="Documentation project for the func package.">
  <main class="mx-auto flex min-h-screen w-full max-w-5xl flex-col px-6 py-10">
    <header class="flex items-center justify-between border-b border-border pb-5">
      <a class="text-sm font-medium tracking-wide text-foreground" href="/">func</a>
      <Button variant="secondary" size="sm">Docs ready</Button>
    </header>

    <section class="grid flex-1 items-center gap-8 py-16 md:grid-cols-[1.2fr_0.8fr]">
      <div class="max-w-2xl">
        <p class="text-sm font-medium text-muted-foreground">Astro documentation</p>
        <h1 class="mt-4 text-4xl font-semibold text-balance md:text-5xl">
          Build and publish docs for func.
        </h1>
        <p class="mt-5 max-w-xl text-base leading-7 text-muted-foreground">
          This workspace is wired for Astro, TypeScript, Tailwind CSS, shadcn, and
          the @norehq Prettier rules.
        </p>
      </div>

      <nav aria-label="Documentation sections" class="grid gap-3">
        <a
          class="rounded-lg border border-border bg-card px-4 py-3 text-sm font-medium text-card-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
          href="/markdown-page">
          Getting started
        </a>
        <a
          class="rounded-lg border border-border bg-card px-4 py-3 text-sm font-medium text-card-foreground transition-colors hover:bg-accent hover:text-accent-foreground"
          href="https://ui.shadcn.com/docs/registry">
          shadcn registry
        </a>
      </nav>
    </section>
  </main>
</Layout>
