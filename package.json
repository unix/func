    "release": "pnpm --filter func release"
  },
  "repository": {
    "type": "git",
    "url": "http://github.com/unix/func"
  },
  "prettier": "@unix/prettier",
  "devDependencies": {
    "@unix/prettier": "^0.1.0",
    "prettier": "^3.8.3"
  }
}
