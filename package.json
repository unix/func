{
  "name": "func-workspace",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "test": "pnpm --filter func test",
    "build": "pnpm --filter func build",
    "docs": "pnpm --filter func docs",
    "docs:dev": "pnpm --filter docs dev",
